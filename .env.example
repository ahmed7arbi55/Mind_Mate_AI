# FastAPI Configuration
API_HOST=127.0.0.1
API_PORT=8000
DEBUG=True
RELOAD=True

# Device Configuration
DEVICE=cpu
# DEVICE=cuda  # Uncomment to use GPU if available

# Model Paths
FACE_MODEL_PATH=yolov8n-face.pt
EMOTION_MODEL_PATH=repvgg.pth

# Detection Settings
FACE_CONF_THRESHOLD=0.5
FACE_IOU_THRESHOLD=0.4
EMOTION_TEMPERATURE=1.0

# API Settings
MAX_UPLOAD_SIZE=10485760  # 10 MB in bytes
REQUEST_TIMEOUT=60

# Logging
LOG_LEVEL=INFO

# Authentication
API_KEY=MySuperSecretKey

# Webhook reliability
WEBHOOK_TIMEOUT_SECONDS=10
WEBHOOK_RETRY_COUNT=3
WEBHOOK_RETRY_DELAY_SECONDS=1.5

# SSL verification for callback URL
WEBHOOK_VERIFY_SSL=True
DISABLE_SSL_VERIFY_FOR_LOCALHOST=True
